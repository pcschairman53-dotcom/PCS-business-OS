# PCS Business OS Backend - Environment Configuration Example

# FastAPI Settings
PROJECT_NAME="PCS Business OS"
ENV="development" # development, production, testing
PORT=3000
API_V1_STR="/api/v1"

# Security & Authentication
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET_KEY="your-super-secret-jwt-key-change-this-in-production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# MongoDB Atlas Database
# Replace with your actual MongoDB Atlas connection string
MONGO_URI="mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority"
MONGO_DB_NAME="pcs_business_os"

# Google Gemini AI API
# AI Studio automatically injects this at runtime from user secrets.
# For local or external deployment, set your Gemini API Key here.
GEMINI_API_KEY="your-gemini-api-key"

# App Deployment URL
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, CORS configuration, and OAuth callbacks.
APP_URL="http://localhost:3000"
